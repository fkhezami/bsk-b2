# Supabase — get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — used server-side only (admin operations, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq — get from https://console.groq.com/keys (used for image extraction + enrichment)
GROQ_API_KEY=your-groq-api-key

# App URL — required on Vercel so the process API can call itself internally
# Leave empty for local dev (auto-detected from request)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
