# Supabase — get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — used server-side only (admin operations, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — get from https://aistudio.google.com/app/apikey (free tier)
GEMINI_API_KEY=your-gemini-api-key

# App URL — required on Vercel so the process API can call itself internally
# Leave empty for local dev (auto-detected from request)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Admin credentials — only used by scripts/seed-admin.ts to create the Supabase user
# Run: npx tsx scripts/seed-admin.ts   (one time only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-deploy
